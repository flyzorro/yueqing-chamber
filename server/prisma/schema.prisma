generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid()) @db.VarChar
  phone     String    @unique @db.VarChar
  password  String    @db.VarChar
  name      String    @db.VarChar
  avatar    String?   @db.VarChar
  createdat DateTime? @default(now()) @db.Timestamp(6)
  updatedat DateTime? @default(now()) @db.Timestamp(6)
}

model Member {
  id            String         @id @default(cuid()) @db.VarChar
  name          String         @db.VarChar
  phone         String         @db.VarChar
  email         String?        @db.VarChar
  company       String         @db.VarChar
  position      String?        @db.VarChar
  joindate      DateTime?      @default(now()) @db.Timestamp(6)
  status        String?        @default("active") @db.VarChar
  createdat     DateTime?      @default(now()) @db.Timestamp(6)
  updatedat     DateTime?      @default(now()) @db.Timestamp(6)

  registrations Registration[]

  @@index([phone])
  @@index([status])
}

model Company {
  id           String    @id @default(cuid()) @db.VarChar
  name         String    @db.VarChar
  industry     String?   @db.VarChar
  contactName  String?   @db.VarChar
  contactPhone String?   @db.VarChar
  summary      String?
  status       String?   @default("active") @db.VarChar
  sortorder    Int?      @default(0)
  createdat    DateTime? @default(now()) @db.Timestamp(6)
  updatedat    DateTime? @default(now()) @db.Timestamp(6)

  @@index([name])
  @@index([status])
  @@index([sortorder])
}

model Activity {
  id                  String        @id @default(cuid()) @db.VarChar
  title               String        @db.VarChar
  description         String?
  date                DateTime      @db.Timestamp(6)
  location            String        @db.VarChar
  maxparticipants     Int
  currentparticipants Int?          @default(0)
  status              String?       @default("upcoming") @db.VarChar
  createdat           DateTime?     @default(now()) @db.Timestamp(6)
  updatedat           DateTime?     @default(now()) @db.Timestamp(6)

  registrations       Registration[]

  @@index([date])
  @@index([status])
}

model Registration {
  id          String    @id @default(cuid()) @db.VarChar
  memberId    String    @db.VarChar
  activityId  String    @db.VarChar
  status      String?   @default("registered") @db.VarChar
  createdat   DateTime? @default(now()) @db.Timestamp(6)
  updatedat   DateTime? @default(now()) @db.Timestamp(6)

  member      Member    @relation(fields: [memberId], references: [id])
  activity    Activity  @relation(fields: [activityId], references: [id])

  @@unique([memberId, activityId])
  @@index([memberId])
  @@index([activityId])
}
