# JWT 密钥（生产环境必须修改为随机字符串）
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 服务器端口
PORT=3000

# 数据库配置（后续使用 PostgreSQL 时配置）
# DATABASE_URL=postgresql://user:password@localhost:5432/yueqing_chamber

# 安全说明：
# 1. 复制此文件为 .env
# 2. 修改 JWT_SECRET 为随机字符串（至少 32 字符）
# 3. 不要将 .env 提交到 git
